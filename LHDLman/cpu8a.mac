; ----------------------------------------------------------------------------
;    MOVR
; ----------------------------------------------------------------------------
macro MOVR _DR,_DR

if ((#0==0) && (#1==0))
   error "MOVR R0,R0 は使用できません。\n"
endif

if ((#0==1) && (#1==1))
   error "MOVR R1,R1 は使用できません。\n"
endif

if ((#0==2) && (#1==2))
   error "MOVR R2,R2 は使用できません。\n"
endif

if ((#0==3) && (#1==3))
   error "MOVR R3,R3 は使用できません。\n"
endif

      db   090h+(#0<<2)+#1
endm

